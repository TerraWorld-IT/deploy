# ===== Shared DB =====
# Shared PostgreSQL used by both Spring Boot (`public` schema, Flyway)
# and better-auth on the Nitro side (`auth` schema, manual init SQL).
# SEC-005: DO NOT store HS256 secrets here — Spring validates JWTs via
# the JWKS endpoint, so there is no shared symmetric secret.
# 도커 스택 기준: DB_HOST=postgres (서비스명), DB_USER=terraworld (compose postgres POSTGRES_USER 와 일치).
DB_HOST=postgres
DB_PORT=5432
DB_NAME=terraworld
DB_USER=terraworld
DB_PASSWORD=change-me

# Composed URLs used by each service.
SPRING_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}?currentSchema=public
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?search_path=auth,public

# ===== better-auth (Nuxt/Nitro) =====
# Signs session cookies and wraps the private RSA keys stored in
# auth.jwks. Generate with `openssl rand -hex 32`. This is NOT shared
# with the Spring backend.
BETTER_AUTH_SECRET=change-me-openssl-rand-hex-32
BETTER_AUTH_URL=https://terraworld.app

# ===== Spring Boot JWT validation =====
# Spring fetches RS256 public keys from better-auth. No symmetric
# secret. AUTH_JWKS_URL must be reachable from the backend container.
AUTH_JWKS_URL=https://terraworld.app/api/auth/jwks
AUTH_JWT_ISSUER=terraworld
AUTH_JWT_AUDIENCE=terraworld-api

# ===== Shared internal token =====
# Used by better-auth databaseHooks (Nitro side) to call Spring's
# internal bootstrap endpoints. MUST be set identically on both sides.
# Transferred out-of-band. Generate with `openssl rand -hex 32`.
INTERNAL_API_TOKEN=change-me-openssl-rand-hex-32
# Nitro(frontend) → Spring(backend) 내부 호출 base. 도커 스택에서는 서비스명 사용.
INTERNAL_API_BASE_URL=http://backend:8080

# ===== CORS =====
# Comma-separated origin list. NEVER include localhost entries when
# SPRING_PROFILES_ACTIVE=prod — SecurityConfig aborts startup.
CORS_ALLOWED_ORIGINS=https://terraworld.app

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379

# ===== Spring profiles =====
SPRING_PROFILES_ACTIVE=prod

# ===== Container Registry =====
REGISTRY_URL=ghcr.io/terraworld-it
TAG=latest

# ===== API base (frontend public) =====
NUXT_PUBLIC_API_BASE_URL=https://terraworld.app/api/v1
NUXT_PUBLIC_AUTH_BASE_URL=https://terraworld.app

# ===== nginx Universal Links / App Links (envsubst — 미설정 시 nginx 서비스 부팅 실패) =====
# SECRETS.md §5b 참고. IOS_TEAM_ID = 10자 Apple Team ID, ANDROID_SHA256_FINGERPRINT = 릴리스 keystore SHA-256.
IOS_TEAM_ID=
ANDROID_SHA256_FINGERPRINT=

# ===== Deploy Server =====
DEPLOY_HOST=
DEPLOY_USER=

# ============================================================================
# 외부 서비스 — 발급 후 활성화 (미설정 시 dormant: 기능만 비활성, 부팅엔 영향 없음)
# 변수명은 backend application.yml / 코드 @Value 와 정확히 일치해야 함 (섹션 3 경고).
# ============================================================================

# ----- E-1 FCM (푸시) -----
# raw JSON 문자열 통째로. 또는 GOOGLE_APPLICATION_CREDENTIALS 로 파일경로 대체 가능.
FCM_SERVICE_ACCOUNT_JSON=

# ----- E-3 AdMob SSV (광고 서버검증) -----
# 기본값은 Google 고정 URL. 보통 그대로 둠. 비공개 테스트 종료 후 nonce 강제:
ADMOB_SSV_PUBLIC_KEY_URL=https://gstatic.com/admob/reward/verifier-keys.json
REWARD_AD_NONCE_REQUIRED=true

# ----- E-6 Cloudflare R2 (사진 저장) — 5개 모두 채워야 활성, 하나라도 빈값이면 base64 fallback -----
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ----- E-4 Play Billing (IAP 검증) -----
# ⚠️ service account 는 raw JSON 이 아니라 파일 "경로". 컨테이너에 마운트 후 경로 지정.
TERRAWORLD_BILLING_PLAY_PACKAGE_NAME=app.terraworld.mobile
TERRAWORLD_BILLING_PLAY_SERVICE_ACCOUNT_JSON_PATH=

# ----- E-3/E-7 클라이언트 노출(public) — 발급 전 비워둠 -----
NUXT_PUBLIC_GA_ID=
NUXT_PUBLIC_ADSENSE_CLIENT=
NUXT_PUBLIC_ADSENSE_SLOT=
NUXT_PUBLIC_ADMOB_REWARDED_AD_ID=

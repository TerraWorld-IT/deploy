# ═══════════════════════════════════════════════════════════════════════════
# TerraWorld 프로덕션 env — 이 파일을 `.env` 로 복사해 값을 채운다.
#   cp env.production.example .env    (또는 scripts/bootstrap.sh 가 자동 생성)
#
# 채우는 사람 = 인프라 호스팅 담당(외부 개발자). 아래 표기:
#   [DOMAIN] 도메인 하나만 바꾸면 되는 값   [FILL] 직접 채움   [GEN] openssl 생성
#   [FIXED] 컨테이너 내부 서비스명(수정 불필요)
# ═══════════════════════════════════════════════════════════════════════════

# ── 도메인 (이거 하나가 SoT) ────────────────────────────────────────────────
# web-qplay.kr 의 서브도메인. 이 값 + 아래 [DOMAIN] 표시된 4개 URL 을 같은 값으로.
# (scripts/bootstrap.sh 를 쓰면 DEPLOY_DOMAIN 하나만 입력해도 전부 채워짐)
DEPLOY_DOMAIN=terraworld.web-qplay.kr

# ── Shared PostgreSQL (public=Flyway, auth=better-auth) ─────────────────────
DB_NAME=terraworld                 # [FILL] 원하는 DB명 (아래 URL 과 일치)
DB_USER=terraworld                 # [FILL]
DB_PASSWORD=change-me              # [FILL] 강한 값
# 컨테이너는 서비스명 postgres 로 접속 [FIXED] — DB_* 바꾸면 아래 2줄도 동기화.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/terraworld?currentSchema=public
DATABASE_URL=postgresql://terraworld:change-me@postgres:5432/terraworld?options=-c%20search_path%3Dauth%2Cpublic

# ── better-auth (Nitro) ─────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-openssl-rand-hex-32   # [GEN] openssl rand -hex 32
BETTER_AUTH_URL=https://terraworld.web-qplay.kr    # [DOMAIN]

# ── Spring JWT 검증 (JWKS fetch) ────────────────────────────────────────────
# [FIXED] 내부 네트워크로 frontend 직접 호출 — nginx hairpin 회피.
AUTH_JWKS_URL=http://frontend:3000/api/auth/jwks
AUTH_JWT_ISSUER=terraworld
AUTH_JWT_AUDIENCE=terraworld-api

# ── 내부 토큰 (Nitro->Spring bootstrap) ─────────────────────────────────────
INTERNAL_API_TOKEN=change-me-openssl-rand-hex-32   # [GEN] 양측 동일, openssl rand -hex 32
INTERNAL_API_BASE_URL=http://backend:8080          # [FIXED] 내부 서비스명

# ── CORS ────────────────────────────────────────────────────────────────────
# prod 프로파일은 localhost 포함 시 부팅 실패 — 공개 origin 만.
CORS_ALLOWED_ORIGINS=https://terraworld.web-qplay.kr   # [DOMAIN]

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis                   # [FIXED]
REDIS_PORT=6379                    # [FIXED]

# ── Spring 프로파일 ─────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── 프론트 public (브라우저/WebView 가 사용) ────────────────────────────────
NUXT_PUBLIC_API_BASE_URL=https://terraworld.web-qplay.kr/api/v1   # [DOMAIN]
NUXT_PUBLIC_AUTH_BASE_URL=https://terraworld.web-qplay.kr         # [DOMAIN]

# ── 컨테이너 레지스트리 (이미지 pull 위치) ──────────────────────────────────
REGISTRY_URL=ghcr.io/terraworld-it   # [FILL] 이재석 님 레지스트리로 교체 가능
TAG=latest                            # [FILL] 특정 커밋 SHA 권장(롤백 용이)

# ── App/Universal Links (nginx AASA/assetlinks) ─────────────────────────────
IOS_TEAM_ID=SMF6T723XR                # [FILL] Apple Team ID (nginx AASA)
ANDROID_SHA256_FINGERPRINT=           # [FILL] Android 릴리스 keystore SHA-256 (콜론구분 대문자hex)

# ── 선택: R2 사진 저장 (미설정 시 base64 fallback) ──────────────────────────
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ── 선택: FCM 푸시 (미설정 시 noop) ─────────────────────────────────────────
# FCM_SERVICE_ACCOUNT_JSON=

# ═══════════════════════════════════════════════════════════════════════════
# 아래는 .env 가 아니라 CI(GitHub Actions) 시크릿에 넣는 값 — 참고용.
#   REGISTRY_URL / REGISTRY_USERNAME / REGISTRY_PASSWORD  (이미지 push)
#   DEPLOY_HOST / DEPLOY_USER / DEPLOY_SSH_KEY            (SSH 배포 대상)
#   API_BASE_URL = https://<DEPLOY_DOMAIN>/api/v1          (frontend 빌드타임)
# ═══════════════════════════════════════════════════════════════════════════
